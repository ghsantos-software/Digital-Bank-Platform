# =============================================================
# Digital Bank Platform - Environment Variables
# Copy this file to .env and adjust the values
# =============================================================

# PostgreSQL
POSTGRES_USER=digitalbank
POSTGRES_PASSWORD=digitalbank123

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Kafka (internal Docker network)
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin123
KEYCLOAK_JWK_SET_URI=http://keycloak:8080/realms/digital-bank/protocol/openid-connect/certs

# Grafana
GRAFANA_ADMIN_PASSWORD=admin123

# Service ports (exposed on host)
CONFIG_SERVER_PORT=8888
DISCOVERY_PORT=8761
GATEWAY_PORT=8080
USER_SERVICE_PORT=8081
ACCOUNT_SERVICE_PORT=8082
TRANSACTION_SERVICE_PORT=8083
