# Normalize line endings to LF on commit
* text=auto eol=lf

# Java source
*.java text eol=lf
*.xml  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.sql  text eol=lf
*.md   text eol=lf
*.sh   text eol=lf

# Force CRLF for Windows batch files
*.cmd  text eol=crlf
*.bat  text eol=crlf

# Binary — do not mangle
*.jar  binary
*.war  binary
*.png  binary
*.jpg  binary
*.gif  binary
